# ── Bright Data ──────────────────────────────────────────────────────────────
# Scraping Browser CDP WebSocket endpoint (REQUIRED)
# Get it: dash.brightdata.com → your zone → "Access parameters" → CDP endpoint
# Format: wss://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:9222
BRIGHT_DATA_CDP=wss://brd-customer-<customer_id>-zone-<zone>:<password>@brd.superproxy.io:9222

# REST API key (OPTIONAL — future use for Bright Data REST endpoints)
# Get it: dash.brightdata.com → Account Settings → API tokens
BRIGHT_DATA_API_KEY=your_api_key_here
