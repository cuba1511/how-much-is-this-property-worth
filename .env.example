# ── Bright Data ──────────────────────────────────────────────────────────────
# Scraping Browser CDP WebSocket endpoint (REQUIRED)
# Get it: dash.brightdata.com → your zone → "Access parameters" → CDP endpoint
# Format: wss://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:9222
BRIGHT_DATA_CDP=wss://brd-customer-<customer_id>-zone-<zone>:<password>@brd.superproxy.io:9222

# REST API key (OPTIONAL — future use for Bright Data REST endpoints)
# Get it: dash.brightdata.com → Account Settings → API tokens
BRIGHT_DATA_API_KEY=your_api_key_here

# ── Public API (Apps Script + Investmap) ─────────────────────────────────────
# Optional shared secret. If set, /api/valuation/simple requires header X-API-Key.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
HV_API_KEY=

# ── Email delivery (Resend) ──────────────────────────────────────────────────
# Used by /api/lead to email the valuation report (HTML branded + PDF attached).
# Get an API key: resend.com → API Keys → Create. Free tier: 3000 emails/month.
RESEND_API_KEY=
# Verified sender. Must match a domain you've added + verified in Resend.
RESEND_FROM_EMAIL=PropHero <noreply@prophero.com>

# ── Persistence ──────────────────────────────────────────────────────────────
# Override the SQLite path. Defaults to backend/data/prophero.db (gitignored).
# Production (Railway volume): /data/prophero.db
HV_DB_PATH=

# ── Production deploy ────────────────────────────────────────────────────────
# Set on Railway. Comma-separated browser origins (your Vercel URL, no trailing slash).
# CORS_ORIGINS=https://your-app.vercel.app
# HV_ENV=production
