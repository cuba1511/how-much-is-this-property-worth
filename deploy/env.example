# Copy to deploy/.env on the VPS (never commit deploy/.env).

# ── Public site ───────────────────────────────────────────────────────────────
# Your domain (HTTPS auto via Caddy). Use ":80" until DNS points to the server.
SITE_ADDRESS=tu-dominio.com
# Let's Encrypt contact (required when SITE_ADDRESS is a real domain)
ACME_EMAIL=tu@email.com

# ── Bright Data (required) ────────────────────────────────────────────────────
BRIGHT_DATA_CDP=wss://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:9222
BRIGHT_DATA_API_KEY=

# ── Email (optional) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=PropHero <noreply@tudominio.com>

# ── API key for Apps Script / simple valuation (optional) ─────────────────────
HV_API_KEY=

# CORS not needed on VPS (same origin). Leave unset.
